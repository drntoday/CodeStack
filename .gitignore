```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Logs
*.log

# Environment variables
.env.local
.env

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
.coverage.*
.nox/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db

# Coverage directory used by tools like istanbul
coverage/
```