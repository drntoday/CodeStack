```gitignore
# Dependencies
node_modules/
.pnpm-store/
.yarn/
.yarn-cache/

# Build outputs
dist/
build/
.next/
out/
.nuxt/
public/dist/
static/dist/

# TypeScript/JavaScript
*.tsbuildinfo
*.js.map
*.ts.map

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage
coverage/
.nyc_output/
istanbul/
```