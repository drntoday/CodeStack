# Groq AI API key from https://console.groq.com/keys 
GROQ_API_KEY=

# GitHub OAuth App credentials
# Create at https://github.com/settings/developers 
# Callback URL: https://<your-vercel-app>.vercel.app/api/auth/callback/github
CODESTACK_GITHUB_ID=
CODESTACK_GITHUB_SECRET=

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# GitHub fine‑grained personal access token for self‑healing
# Needs Contents (read/write), Pull requests (read/write), Actions (read)
HEALER_TOKEN=

# Secret for GitHub webhook signature verification
# Use the same value in GitHub webhook settings
WEBHOOK_SECRET=

# NextAuth URL (set to https://your-app.vercel.app in production)
NEXTAUTH_URL=http://localhost:3000

# Vercel KV connection string (auto-provisioned when you add KV to your project)
VERCEL_KV_URL=
